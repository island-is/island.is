{
  "name": "clients-rsk-customs-general",
  "$schema": "../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/clients/rsk/customs/general/src",
  "projectType": "library",
  "tags": ["lib:client", "scope:client"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/clients/rsk/customs/general/jest.config.ts"
      }
    },
    "codegen/backend-client": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn openapi-ts -f libs/clients/rsk/customs/general/src/lib/openapi-ts.config.ts"
      },
      "outputs": ["{projectRoot}/gen/fetch"]
    }
  }
}
