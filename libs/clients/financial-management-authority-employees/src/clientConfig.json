{
  "openapi": "3.0.1",
  "info": {
    "title": "Elfur API - Organization",
    "description": "<h2>Organization</h2><p>Status: Beta</p><p><strong>Sections:</strong> Core, Units, Employees</p><h3>Authentication</h3>\r\n<ul>\r\n  <li><strong>Authorization:</strong> <code>Bearer &lt;access_token&gt;</code> is required.</li>\r\n  <li><strong>Required scopes:</strong> <code>@fjs.is/elfur_employee_read</code>, <code>@fjs.is/elfur_organization_read</code></li>\r\n  \r\n</ul>",
    "version": "1.0"
  },
  "paths": {
    "/v1/organization": {
      "get": {
        "tags": ["Organization"],
        "summary": "Get a list of organizations (stofnanir).",
        "description": "Set `isSalaryPayer = true` (default) for salary-paying organizations, or `false` for projects.",
        "parameters": [
          {
            "name": "validFrom",
            "in": "query",
            "description": "(Optional) Filter by date. The start date of the organization.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "validTo",
            "in": "query",
            "description": "(Optional) Filter by date. The end date of the organization.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "(Optional) Free-text filter applied across ministry/organization name, code, abbreviation and national identifier.",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "isSalaryPayer",
            "in": "query",
            "description": "If true, returns only salary-paying organizations (default). If false, returns projects/non-salary organizations.",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "rowOffset",
            "in": "query",
            "description": "(Optional) Offset for pagination. Row where to start fetching from.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "fetchSize",
            "in": "query",
            "description": "(Optional) Fetch size for pagination. Clamped to the range [1, 1000].",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Total-Count": {
                "description": "Total number of rows matching the query, ignoring offset and fetch size.",
                "schema": {
                  "type": "integer",
                  "example": 1234
                }
              },
              "Row-Offset": {
                "description": "Offset that was applied to this response (matches the rowOffset request parameter after clamping).",
                "schema": {
                  "type": "integer",
                  "example": 0
                }
              },
              "Fetch-Size": {
                "description": "Fetch size that was applied to this response (matches the fetchSize request parameter after clamping).",
                "schema": {
                  "type": "integer",
                  "example": 25
                }
              },
              "Has-Next-Page": {
                "description": "True when more rows exist past the end of the current page (rowOffset + items < Total-Count).",
                "schema": {
                  "type": "boolean",
                  "example": true
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OrganizationDto"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/v1/organization/{fjarlagalidurConstant}": {
      "get": {
        "tags": ["Organization"],
        "summary": "Get a single organization by its fjárlaganúmer.",
        "parameters": [
          {
            "name": "fjarlagalidurConstant",
            "in": "path",
            "description": "The organization's fjárlaganúmer (matches `Organizations.organizationCode` in ELFUR_DATAMART).",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "isSalaryPayer",
            "in": "query",
            "description": "If true, returns the organization only if it is a salary payer (default). If false, returns it only if it is a project/non-salary organization.",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganizationDto"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/v1/organization/{fjarlagalidurConstant}/employees": {
      "get": {
        "tags": ["OrganizationEmployee"],
        "summary": "Get employees for an organization, optionally filtered to a specific unit.",
        "description": "\nOmit `organizationUnitNumber` (or set to 0) to get all employees in the organization.\r\n\nSet `activeOnly = true` to return only employees with AssignmentStatusGroup = 'ACTIVE_ASSIGN'.\r\n\nAuthorization is based on the `client_id` from the bearer token.",
        "parameters": [
          {
            "name": "fjarlagalidurConstant",
            "in": "path",
            "description": "The organization's fjárlaganúmer (matches `OrganizationEmployees.parentOrganizationId` in ELFUR_DATAMART).",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "organizationUnitNumber",
            "in": "query",
            "description": "(Optional) Organization unit number (ie. deild). If used, only employees for the given OU will be returned. If not set or set to 0, all employees for that organization will be returned.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "activeOnly",
            "in": "query",
            "description": "(Optional) If true, returns only active employees (AssignmentStatusGroup = 'ACTIVE_ASSIGN'). If false or not provided, returns all employees.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "rowOffset",
            "in": "query",
            "description": "(Optional) Offset for pagination. Row where to start fetching from.",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "fetchSize",
            "in": "query",
            "description": "(Optional) Fetch size for pagination. Clamped to the range [1, 1000].",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Total-Count": {
                "description": "Total number of rows matching the query, ignoring offset and fetch size.",
                "schema": {
                  "type": "integer",
                  "example": 1234
                }
              },
              "Row-Offset": {
                "description": "Offset that was applied to this response (matches the rowOffset request parameter after clamping).",
                "schema": {
                  "type": "integer",
                  "example": 0
                }
              },
              "Fetch-Size": {
                "description": "Fetch size that was applied to this response (matches the fetchSize request parameter after clamping).",
                "schema": {
                  "type": "integer",
                  "example": 25
                }
              },
              "Has-Next-Page": {
                "description": "True when more rows exist past the end of the current page (rowOffset + items < Total-Count).",
                "schema": {
                  "type": "boolean",
                  "example": true
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EmployeeBasicResponseDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
