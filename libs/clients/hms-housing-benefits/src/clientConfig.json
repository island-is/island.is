{
  "openapi": "3.0.1",
  "info": {
    "title": "HusbotAPI",
    "description": "HusbotAPI is an interface for managing housing benefits and related operations.",
    "version": "v1"
  },
  "paths": {
    "/api/v{version}/Application/createHousingBenefitsApplication": {
      "post": {
        "tags": ["Application"],
        "summary": "Creates a new housing benefits application.",
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "The housing benefits application data.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HousingBenefitsApplicationModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/HousingBenefitsApplicationModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/HousingBenefitsApplicationModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HousingBenefitsApplicationReturnModel"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HousingBenefitsApplicationReturnModel"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HousingBenefitsApplicationReturnModel"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/ModelStateEntry"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/ModelStateEntry"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "$ref": "#/components/schemas/ModelStateEntry"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/api/v{version}/Payment/paymenthistory": {
      "post": {
        "tags": ["Payment"],
        "summary": "Retrieves information about payment history for all payments for logged in individual in the Husbot system with pagination.",
        "parameters": [
          {
            "name": "dateFrom",
            "in": "query",
            "description": "Date from which the payment history is retrieved",
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "dateTo",
            "in": "query",
            "description": "Date to which the payment history is retrieved",
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "pageNumber",
            "in": "query",
            "description": "The number of page",
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Limits the number of results in a request.",
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "paymentOrigin",
            "in": "query",
            "description": "Origin of payment, e.g.standard payments(Húsbót) or special payments(Sérstakar). 0= Both, 1= Almennar, 2=Sérstakar",
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "month",
            "in": "query",
            "description": "Payment for rental month.",
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "payments",
            "in": "query",
            "description": "Show payments only if true, else also show final settlements.",
            "style": "form",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentsReturnModelPaginationResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentsReturnModelPaginationResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentsReturnModelPaginationResponse"
                }
              }
            }
          },
          "204": {
            "description": "No Content",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/NoContent"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoContent"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoContent"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequest"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequest"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequest"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApplicationFile": {
        "type": "object",
        "properties": {
          "kennitala": {
            "type": "string",
            "nullable": true
          },
          "applicationNumber": {
            "type": "integer",
            "format": "int32"
          },
          "fileUrl": {
            "type": "string",
            "nullable": true
          },
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "fileType": {
            "$ref": "#/components/schemas/ApplicationFileType"
          }
        },
        "additionalProperties": false
      },
      "ApplicationFileType": {
        "enum": [1, 2, 3, 4, 5, 6, 7, 8, 9],
        "type": "integer",
        "format": "int32"
      },
      "BadRequest": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "ExemptionType": {
        "enum": [1, 2, 3, 4, 5, 6],
        "type": "integer",
        "format": "int32"
      },
      "HouseholdMember": {
        "type": "object",
        "properties": {
          "kennitala": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "postalCode": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "type": "string",
            "nullable": true
          },
          "acceptedPrivacyPolicy": {
            "type": "boolean"
          },
          "acceptedMunicipalityDataFetch": {
            "type": "boolean"
          },
          "acceptedDataFetch": {
            "type": "boolean"
          },
          "exemptionNumber": {
            "$ref": "#/components/schemas/ExemptionType"
          }
        },
        "additionalProperties": false
      },
      "HousingBenefitsApplicationModel": {
        "required": [
          "accountNumber",
          "address",
          "bank",
          "email",
          "islandIsDateRegistered",
          "kennitala",
          "leaseContractNumber",
          "ledger",
          "municipality",
          "phoneNumber",
          "postalCode"
        ],
        "type": "object",
        "properties": {
          "islandIsApplicationNumber": {
            "type": "integer",
            "format": "int32"
          },
          "kennitala": {
            "minLength": 1,
            "type": "string"
          },
          "address": {
            "minLength": 1,
            "type": "string"
          },
          "municipality": {
            "minLength": 1,
            "type": "string"
          },
          "postalCode": {
            "minLength": 1,
            "type": "string"
          },
          "islandIsDateRegistered": {
            "type": "string",
            "format": "date-time"
          },
          "phoneNumber": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "bank": {
            "minLength": 1,
            "type": "string"
          },
          "ledger": {
            "minLength": 1,
            "type": "string"
          },
          "accountNumber": {
            "minLength": 1,
            "type": "string"
          },
          "leaseContractNumber": {
            "type": "integer",
            "format": "int32"
          },
          "propertyNumber": {
            "type": "string",
            "nullable": true
          },
          "foreignIncome": {
            "type": "string",
            "nullable": true
          },
          "contractorIncome": {
            "type": "string",
            "nullable": true
          },
          "otherIncome": {
            "type": "string",
            "nullable": true
          },
          "payToLandlord": {
            "type": "integer",
            "format": "int32"
          },
          "landlordBankAccountOwnerKennitala": {
            "type": "string",
            "nullable": true
          },
          "landlordBank": {
            "type": "string",
            "nullable": true
          },
          "landlordLedger": {
            "type": "string",
            "nullable": true
          },
          "landlordAccountNumber": {
            "type": "string",
            "nullable": true
          },
          "hasAssetsAndIncome": {
            "type": "integer",
            "format": "int32"
          },
          "householdMembers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HouseholdMember"
            },
            "nullable": true
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApplicationFile"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "HousingBenefitsApplicationReturnModel": {
        "type": "object",
        "properties": {
          "applicationNumber": {
            "type": "integer",
            "description": "Application number. Original Icelandic name: UmsoknNr.",
            "format": "int32"
          },
          "success": {
            "type": "boolean",
            "description": "Specifies if the application was successful."
          }
        },
        "additionalProperties": false,
        "description": "from Housing benefit System."
      },
      "ModelError": {
        "type": "object",
        "properties": {
          "errorMessage": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "ModelStateEntry": {
        "type": "object",
        "properties": {
          "rawValue": {
            "nullable": true,
            "type": "object"
          },
          "attemptedValue": {
            "type": "string",
            "nullable": true
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelError"
            },
            "nullable": true,
            "readOnly": true
          },
          "validationState": {
            "$ref": "#/components/schemas/ModelValidationState"
          },
          "isContainerNode": {
            "type": "boolean",
            "readOnly": true
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelStateEntry"
            },
            "nullable": true,
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "ModelValidationState": {
        "enum": [0, 1, 2, 3],
        "type": "integer",
        "format": "int32"
      },
      "NoContent": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "NotFound": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "PageInfo": {
        "type": "object",
        "properties": {
          "hasPreviousPage": {
            "type": "boolean"
          },
          "hasNextPage": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "PaymentsReturnModel": {
        "type": "object",
        "properties": {
          "nr": {
            "type": "integer",
            "description": "Payment Number from Housing benefit System.",
            "format": "int32"
          },
          "kennitala": {
            "type": "string",
            "description": "SSN of the person receiving the Housing Benefits payments.",
            "nullable": true
          },
          "name": {
            "type": "string",
            "description": "Name of the person receiving the Housing Benefits payments.",
            "nullable": true
          },
          "address": {
            "type": "string",
            "description": "Application adress.",
            "nullable": true
          },
          "noDays": {
            "type": "integer",
            "description": "Number of days within a rental month.",
            "format": "int32"
          },
          "dateCalculation": {
            "type": "string",
            "description": "Date of calculation of payments done in the Housing Benefit System.",
            "format": "date-time",
            "nullable": true
          },
          "month": {
            "type": "string",
            "description": "Payment for rental month.",
            "nullable": true
          },
          "dateTransfer": {
            "type": "string",
            "description": "Date of payment transfer to account.",
            "format": "date-time",
            "nullable": true
          },
          "transactionType": {
            "type": "string",
            "description": "Type of transaction e.g. G(payment) K(claim) and L(FinalSettlement).",
            "nullable": true
          },
          "calculationType": {
            "type": "string",
            "description": "Type of calculation e.g. \"Claim paid\", \"re-calculation\" , \"Final Settlement\", \"Calculation\".",
            "nullable": true
          },
          "paymentActual": {
            "type": "integer",
            "description": "Actual payment.",
            "format": "int32"
          },
          "bankAccountMerged": {
            "type": "string",
            "description": "Bank account of the person receiving payment.",
            "nullable": true
          },
          "paidOfDebt": {
            "type": "number",
            "description": "Amount paid of Debt.",
            "format": "double",
            "nullable": true
          },
          "paymentBeforeDebt": {
            "type": "number",
            "description": "Payment before Debt.",
            "format": "double"
          },
          "benefit": {
            "type": "number",
            "description": "Basis for Benefit Rights.",
            "format": "double",
            "nullable": true
          },
          "reductionIncome": {
            "type": "number",
            "description": "Reduction due to applicant income.",
            "format": "double",
            "nullable": true
          },
          "reductionAssets": {
            "type": "number",
            "description": "Reduction due to applicant assest.",
            "format": "double",
            "nullable": true
          },
          "reductionHousingCost": {
            "type": "number",
            "description": "Reduction due to applicant housing cost.",
            "format": "double",
            "nullable": true
          },
          "totalIncome": {
            "type": "integer",
            "description": "Total income of applicant.",
            "format": "int32",
            "nullable": true
          },
          "remainDebt": {
            "type": "integer",
            "description": "Total debt.",
            "format": "int32",
            "nullable": true
          },
          "paymentOrigin": {
            "type": "integer",
            "description": "Origin of payment, e.g. special payments(Sérstakar) or standard payments(Húsbót).",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Payment Number from Housing benefit System."
      },
      "PaymentsReturnModelPaginationResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PaymentsReturnModel"
            },
            "nullable": true
          },
          "pageInfo": {
            "$ref": "#/components/schemas/PageInfo"
          },
          "totalCount": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "JWT Authorization header using the Bearer scheme. \r\n\r\n Enter 'Bearer' [space] and then your token in the text input below.\r\n\r\nExample: \"Bearer 1safsfsdfdfd\"",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": []
    }
  ]
}
