{
  "openapi": "3.0.1",
  "info": {
    "title": "HusbotAPI",
    "description": "HusbotAPI is an interface for managing housing benefits and related operations.",
    "version": "v1"
  },
  "paths": {
    "/api/v{version}/Application/createHousingBenefitsApplication": {
      "post": {
        "tags": ["Application"],
        "summary": "Creates a new housing benefits application.",
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "The housing benefits application data.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HousingBenefitsApplicationModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/HousingBenefitsApplicationModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/HousingBenefitsApplicationModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Application created successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HousingBenefitsApplicationReturnModel"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HousingBenefitsApplicationReturnModel"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HousingBenefitsApplicationReturnModel"
                }
              }
            }
          },
          "400": {
            "description": "Invalid model state",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "An internal server error occurred."
          }
        }
      }
    },
    "/api/v{version}/Application/hasTaxReturnForYear": {
      "get": {
        "tags": ["Tax"],
        "summary": "Check if a tax return exists for a specific year",
        "description": "Queries RSK to determine whether the authenticated user has filed a tax return (skattframtal) for the given income year (tekjuár).",
        "operationId": "HasTaxReturnForYear",
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "description": "The income year (tekjuár) to check.",
            "required": true,
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns true if a tax return has been filed, false otherwise.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "boolean"
                }
              },
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              },
              "text/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "400": {
            "description": "Year is missing or invalid."
          },
          "500": {
            "description": "An unexpected error occurred while querying RSK."
          }
        }
      }
    },
    "/api/v{version}/Application/hasTaxReturnLastFiveYears": {
      "get": {
        "tags": ["Tax"],
        "summary": "Check if a tax return exists in the last 5 years",
        "description": "Queries RSK to determine whether the authenticated user has filed a tax return (skattframtal) in any of the last 5 income years (tekjuár). Returns true on the first year found.",
        "operationId": "HasTaxReturnLastFiveYears",
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns true if a tax return has been filed in any of the last 5 years, false otherwise.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "boolean"
                }
              },
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              },
              "text/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          },
          "400": {
            "description": "Unable to resolve kennitala from token."
          },
          "500": {
            "description": "An unexpected error occurred while querying RSK."
          }
        }
      }
    },
    "/api/v{version}/Application/test": {
      "post": {
        "tags": ["Application"],
        "summary": "Simple POST test endpoint to verify API availability and authentication.",
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API is working",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "type": "string"
                }
              },
              "text/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Application"],
        "summary": "Simple GET test endpoint to verify API availability from a browser.",
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API is working",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "type": "string"
                }
              },
              "text/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/v{version}/Application/diag-dal": {
      "get": {
        "tags": ["Application"],
        "summary": "TEMP DIAG: Runs DAL steps individually with timing. Returns partial results after 20s timeout.",
        "parameters": [
          {
            "name": "run",
            "in": "query",
            "style": "form",
            "schema": {
              "type": "string",
              "default": "no"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/v{version}/Application/diag-db": {
      "get": {
        "tags": ["Application"],
        "summary": "TEMP DIAG: Shows what connection strings the DAL actually resolves to.",
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/v{version}/Application/diag-token": {
      "get": {
        "tags": ["Application"],
        "summary": "TEMP DIAG: Tests the full LeiguskraDAL flow - token + housing-benefit GET with contract_status filter.",
        "parameters": [
          {
            "name": "kennitala",
            "in": "query",
            "style": "form",
            "schema": {
              "type": "string",
              "default": "1910824439"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/v{version}/Payment/paymenthistory": {
      "post": {
        "tags": ["Payment"],
        "summary": "Retrieves information about payment history for all payments for logged in individual in the Husbot system with pagination.",
        "parameters": [
          {
            "name": "dateFrom",
            "in": "query",
            "description": "Date from which the payment history is retrieved",
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "dateTo",
            "in": "query",
            "description": "Date to which the payment history is retrieved",
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "pageNumber",
            "in": "query",
            "description": "The number of page",
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Limits the number of results in a request.",
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "paymentOrigin",
            "in": "query",
            "description": "Origin of payment, e.g.standard payments(H�sb�t) or special payments(S�rstakar). 0= Both, 1= Almennar, 2=S�rstakar",
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "month",
            "in": "query",
            "description": "Payment for rental month.",
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "payments",
            "in": "query",
            "description": "Show payments only if true, else also show final settlements.",
            "style": "form",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "version",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of payments",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentsReturnModelPaginationResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentsReturnModelPaginationResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentsReturnModelPaginationResponse"
                }
              }
            }
          },
          "204": {
            "description": "No Content",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/NoContent"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoContent"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoContent"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFound"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequest"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequest"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequest"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApplicationFile": {
        "type": "object",
        "properties": {
          "kennitala": {
            "type": "string",
            "description": "Kennitala of the household member that sent in the file",
            "nullable": true
          },
          "applicationNumber": {
            "type": "integer",
            "description": "Application number of the application the file is attached to.",
            "format": "int32"
          },
          "fileUrl": {
            "type": "string",
            "description": "Presigned URL that can be fetched within 5 min after submit. Husbot fetches immediately automatically.",
            "nullable": true
          },
          "fileName": {
            "type": "string",
            "description": "Name of the file.",
            "nullable": true
          },
          "fileType": {
            "$ref": "#/components/schemas/ApplicationFileType"
          }
        },
        "additionalProperties": false,
        "description": "Represents a file attached to a household member."
      },
      "ApplicationFileType": {
        "enum": [
          "visitationAgreement",
          "incomeData",
          "schoolCertificate",
          "medicalCertificate",
          "employmentContract",
          "contractorIncome",
          "foreignIncome",
          "otherIncome",
          "halfwayHouseConfirmation"
        ],
        "type": "string",
        "description": "Represents the purpose of the application file.<br/><b>Members:</b><ul><li><i>1 - VisitationAgreement</i>: Visitation agreement. Original Icelandic name: Umgengnissamningur.</li><li><i>2 - IncomeData</i>: Income data.</li><li><i>3 - SchoolCertificate</i>: School certificate.</li><li><i>4 - MedicalCertificate</i>: Medical certificate.</li><li><i>5 - EmploymentContract</i>: Employment contract.</li><li><i>6 - ContractorIncome</i>: Contractor income.</li><li><i>7 - ForeignIncome</i>: Foreign income.</li><li><i>8 - OtherIncome</i>: Other income.</li><li><i>9 - HalfwayHouseConfirmation</i>: Confirmation of stay at a halfway house.</li></ul>"
      },
      "BadRequest": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "ExemptionType": {
        "enum": [
          "education",
          "illness",
          "halfwayHouse",
          "employment",
          "discrepancy",
          "relocation"
        ],
        "type": "string",
        "description": "Represents the exemption types. Original Icelandic name: UndanthagaEnum."
      },
      "HouseholdMember": {
        "type": "object",
        "properties": {
          "kennitala": {
            "type": "string",
            "description": "The national identification number.",
            "nullable": true
          },
          "address": {
            "type": "string",
            "description": "The street address.",
            "nullable": true
          },
          "postalCode": {
            "type": "string",
            "description": "The postal code.",
            "nullable": true
          },
          "email": {
            "type": "string",
            "description": "The email address.",
            "nullable": true
          },
          "phoneNumber": {
            "type": "string",
            "description": "The phone number.",
            "nullable": true
          },
          "acceptedPrivacyPolicy": {
            "type": "boolean",
            "description": "Whether the privacy policy has been accepted."
          },
          "acceptedMunicipalityDataFetch": {
            "type": "boolean",
            "description": "Whether municipality data fetch has been accepted."
          },
          "acceptedDataFetch": {
            "type": "boolean",
            "description": "Whether data fetch has been accepted."
          },
          "exemptionNumber": {
            "$ref": "#/components/schemas/ExemptionType"
          },
          "assetDeclaration": {
            "type": "string",
            "description": "Asset declaration (Eignayfirlýsing).",
            "nullable": true
          },
          "incomeDeclaration": {
            "type": "string",
            "description": "Income declaration (Tekjuyfirlýsing).",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Contains information about a household member. Original Icelandic name: Heimilismadur."
      },
      "HousingBenefitsApplicationModel": {
        "required": [
          "accountNumber",
          "address",
          "bank",
          "email",
          "islandIsDateRegistered",
          "kennitala",
          "leaseContractNumber",
          "ledger",
          "municipality",
          "phoneNumber",
          "postalCode"
        ],
        "type": "object",
        "properties": {
          "islandIsApplicationNumber": {
            "type": "integer",
            "description": "The Island.is application number. This is used to link the application in Island.is to the application in Husbot. It is generated by Island.is when the application is created.",
            "format": "int32"
          },
          "kennitala": {
            "minLength": 1,
            "type": "string",
            "description": "The national identification number."
          },
          "address": {
            "minLength": 1,
            "type": "string",
            "description": "The address."
          },
          "municipality": {
            "minLength": 1,
            "type": "string",
            "description": "The municipality."
          },
          "postalCode": {
            "minLength": 1,
            "type": "string",
            "description": "The postal code."
          },
          "islandIsDateRegistered": {
            "type": "string",
            "description": "The date the application was registered in Island.is.",
            "format": "date-time"
          },
          "phoneNumber": {
            "minLength": 1,
            "type": "string",
            "description": "The phone number."
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "description": "The email address.",
            "format": "email"
          },
          "bank": {
            "minLength": 1,
            "type": "string",
            "description": "The bank name."
          },
          "ledger": {
            "minLength": 1,
            "type": "string",
            "description": "The ledger number."
          },
          "accountNumber": {
            "minLength": 1,
            "type": "string",
            "description": "The account number."
          },
          "leaseContractNumber": {
            "type": "integer",
            "description": "The lease contract number.",
            "format": "int32"
          },
          "propertyNumber": {
            "type": "string",
            "description": "The property number.",
            "nullable": true
          },
          "propertyTypeNumber": {
            "$ref": "#/components/schemas/PropertyType"
          },
          "foreignIncome": {
            "type": "string",
            "description": "The foreign income.",
            "nullable": true
          },
          "contractorIncome": {
            "type": "string",
            "description": "The contractor income.",
            "nullable": true
          },
          "otherIncome": {
            "type": "string",
            "description": "The other income.",
            "nullable": true
          },
          "payToLandlord": {
            "type": "integer",
            "description": "Indicates whether payment is made to the landlord.",
            "format": "int32"
          },
          "landlordBankAccountOwnerKennitala": {
            "type": "string",
            "description": "The landlord's national identification number.",
            "nullable": true
          },
          "landlordBank": {
            "type": "string",
            "description": "The landlord's bank.",
            "nullable": true
          },
          "landlordLedger": {
            "type": "string",
            "description": "The landlord's ledger.",
            "nullable": true
          },
          "landlordAccountNumber": {
            "type": "string",
            "description": "The landlord's account number.",
            "nullable": true
          },
          "hasAssetsAndIncome": {
            "type": "integer",
            "description": "Indicates whether the applicant has assets and income.",
            "format": "int32"
          },
          "householdMembers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HouseholdMember"
            },
            "description": "The household members.",
            "nullable": true
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApplicationFile"
            },
            "description": "The attached application files.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Model that represents the housing benefits application."
      },
      "HousingBenefitsApplicationReturnModel": {
        "type": "object",
        "properties": {
          "applicationNumber": {
            "type": "integer",
            "description": "Application number. Original Icelandic name: UmsoknNr.",
            "format": "int32",
            "nullable": true
          },
          "success": {
            "type": "boolean",
            "description": "Specifies if the application was successful."
          }
        },
        "additionalProperties": false,
        "description": "from Housing benefit System."
      },
      "NoContent": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "NotFound": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "PageInfo": {
        "type": "object",
        "properties": {
          "hasPreviousPage": {
            "type": "boolean"
          },
          "hasNextPage": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "PaymentsReturnModel": {
        "type": "object",
        "properties": {
          "nr": {
            "type": "integer",
            "description": "Payment Number from Housing benefit System.",
            "format": "int32"
          },
          "kennitala": {
            "type": "string",
            "description": "SSN of the person receiving the Housing Benefits payments.",
            "nullable": true
          },
          "name": {
            "type": "string",
            "description": "Name of the person receiving the Housing Benefits payments.",
            "nullable": true
          },
          "address": {
            "type": "string",
            "description": "Application adress.",
            "nullable": true
          },
          "noDays": {
            "type": "integer",
            "description": "Number of days within a rental month.",
            "format": "int32"
          },
          "dateCalculation": {
            "type": "string",
            "description": "Date of calculation of payments done in the Housing Benefit System.",
            "format": "date-time",
            "nullable": true
          },
          "month": {
            "type": "string",
            "description": "Payment for rental month.",
            "nullable": true
          },
          "dateTransfer": {
            "type": "string",
            "description": "Date of payment transfer to account.",
            "format": "date-time",
            "nullable": true
          },
          "transactionType": {
            "type": "string",
            "description": "Type of transaction e.g. G(payment) K(claim) and L(FinalSettlement).",
            "nullable": true
          },
          "calculationType": {
            "type": "string",
            "description": "Type of calculation e.g. \"Claim paid\", \"re-calculation\" , \"Final Settlement\", \"Calculation\".",
            "nullable": true
          },
          "paymentActual": {
            "type": "integer",
            "description": "Actual payment.",
            "format": "int32"
          },
          "bankAccountMerged": {
            "type": "string",
            "description": "Bank account of the person receiving payment.",
            "nullable": true
          },
          "paidOfDebt": {
            "type": "number",
            "description": "Amount paid of Debt.",
            "format": "double",
            "nullable": true
          },
          "paymentBeforeDebt": {
            "type": "number",
