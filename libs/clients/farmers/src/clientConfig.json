{
  "openapi": "3.0.0",
  "info": {
    "title": "Farmers island api",
    "version": "1.0",
    "contact": {
      "name": "Stefna ehf",
      "url": "https://stefna.is",
      "email": "no-support@stefna.is"
    }
  },
  "servers": [{ "url": "https://staging.api.afurd.is" }],
  "tags": [],
  "paths": {
    "/v1/island/farms": {
      "get": {
        "operationId": "listFarms",
        "description": "list of farms",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListFarm" }
              }
            },
            "description": "ok"
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/island/farms/{farmId}/beneficiaries": {
      "parameters": [
        {
          "in": "path",
          "required": true,
          "name": "farmId",
          "description": "B\u00fasn\u00famer",
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "operationId": "listBeneficiaries",
        "description": "list of beneficiaries of a farm",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListBeneficiaries" }
              }
            },
            "description": "ok"
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/island/farms/{farmId}/assets": {
      "parameters": [
        {
          "in": "path",
          "required": true,
          "name": "farmId",
          "description": "B\u00fasn\u00famer",
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "operationId": "listAssets",
        "description": "list of assets for a farm",
        "parameters": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListAssets" }
              }
            },
            "description": "ok"
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/island/farms/{farmId}/payments": {
      "parameters": [
        {
          "in": "path",
          "required": true,
          "name": "farmId",
          "description": "B\u00fasn\u00famer",
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "operationId": "searchPayments",
        "description": "Search all payments for a farm",
        "parameters": [
          {
            "schema": { "type": "integer" },
            "in": "query",
            "name": "paymentCategoryId",
            "description": "Find by paymentCategoryId, options found in filterOptions in response",
            "example": "521"
          },
          {
            "schema": { "type": "string" },
            "in": "query",
            "name": "contractId",
            "description": "Find by contractId, options found in filterOptions in response",
            "example": "04801"
          },
          {
            "schema": { "type": "string", "format": "date" },
            "in": "query",
            "name": "paymentDate",
            "description": "Find by payment date, a single day",
            "example": "2025-08-01"
          },
          {
            "schema": { "type": "string", "format": "date" },
            "in": "query",
            "name": "paymentDate.from",
            "description": "From or since a specific date, can be used with paymentDate.to for a complete range",
            "example": "2025-08-01"
          },
          {
            "schema": { "type": "string", "format": "date" },
            "in": "query",
            "name": "paymentDate.to",
            "description": "To or until a specific date, can be used with paymentDate.from for a complete range",
            "example": "2025-08-31"
          },
          {
            "schema": { "type": "string" },
            "in": "query",
            "name": "next",
            "description": "The pagination hash, next or previous keys in answer can be used here"
          },
          {
            "schema": { "type": "integer" },
            "in": "query",
            "name": "limit",
            "description": "Default is 20, will not be used when using the next query parameter"
          },
          {
            "schema": { "type": "string" },
            "in": "query",
            "name": "order",
            "example": "-contract",
            "examples": {
              "withoutDirection": { "value": "paymentCategory" },
              "descOrder": { "value": "-paymentDate" },
              "ascOrder": { "value": "-contract" }
            },
            "description": "Default is -paymentDate, +- as first character is optional direction, + is asc and - is desc"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedPayments" }
              }
            },
            "description": "ok"
          },
          "400": { "$ref": "#/components/responses/InputError" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ListFarm": {
        "type": "object",
        "readOnly": true,
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Farm" }
          }
        }
      },
      "Farm": {
        "type": "object",
        "properties": {
          "farmId": {
            "type": "integer",
            "description": "",
            "minimum": 1000000,
            "maximum": 9999999
          },
          "farmName": { "type": "string", "description": "b\u00fanumer" }
        }
      },
      "Error": {
        "title": "Generic Error Object",
        "type": "object",
        "properties": {
          "messages": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "ListBeneficiaries": {
        "type": "object",
        "readOnly": true,
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BeneficiaryWrapper" }
          }
        }
      },
      "BeneficiaryWrapper": {
        "type": "object",
        "properties": {
          "details": {
            "type": "object",
            "properties": {
              "beneficiaryName": { "type": "string" },
              "beneficiaryNationalId": { "type": "string" },
              "beneficiaryBankInfo": { "type": "string" },
              "beneficiaryIsat": { "type": "string" },
              "beneficiaryVsk": { "type": "string" }
            }
          },
          "list": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BeneficiaryPaymentType" }
          }
        }
      },
      "BeneficiaryPaymentType": {
        "type": "object",
        "properties": {
          "paymentCategoryId": { "type": "integer" },
          "paymentCategory": { "type": "string" },
          "share": { "type": "string" },
          "paymentStop": { "type": "string" },
          "operating": { "type": "string" },
          "from": { "type": "string", "format": "date" },
          "to": { "type": "string", "format": "date" }
        }
      },
      "ListAssets": {
        "type": "object",
        "readOnly": true,
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AssetOwner" }
          }
        }
      },
      "AssetOwner": {
        "type": "object",
        "properties": {
          "details": {
            "type": "object",
            "properties": {
              "farmName": { "type": "string" },
              "farmId": { "type": "string" },
              "name": { "type": "string" },
              "nationalId": { "type": "string" }
            }
          },
          "list": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Asset" }
          }
        }
      },
      "Asset": {
        "type": "object",
        "properties": {
          "ownerType": { "type": "string" },
          "usage": { "type": "string" },
          "share": { "type": "string" }
        }
      },
      "PaginatedPayments": {
        "type": "object",
        "readOnly": true,
        "properties": {
          "next": { "type": "string", "nullable": true },
          "previous": { "type": "string", "nullable": true },
          "total": { "nullable": true, "type": "integer" },
          "filterOptions": {
            "type": "object",
            "properties": {
              "contracts": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Contract" }
              },
              "paymentCategories": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/PaymentCategory" }
              }
            }
          },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Payment" }
          }
        }
      },
      "Contract": {
        "type": "object",
        "properties": {
          "contractId": { "type": "string" },
          "contractName": { "type": "string" }
        }
      },
      "PaymentCategory": {
        "type": "object",
        "properties": {
          "paymentCategoryId": { "type": "integer" },
          "paymentCategoryName": { "type": "string" }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Unique payment identifier" },
          "farmId": { "type": "integer", "example": "1234561" },
          "paymentDate": {
            "type": "string",
            "format": "date",
            "example": "2025-01-01"
          },
          "nationalId": {
            "type": "string",
            "description": "National id / social security number"
          },
          "name": { "type": "string", "description": "Persons name" },
          "contractId": { "type": "string", "example": "04801" },
          "contract": { "type": "string" },
          "paymentCategoryId": { "type": "integer" },
          "paymentCategory": { "type": "string" },
          "unitPrice": { "type": "number", "description": "Unit price" },
          "units": { "type": "number", "description": "Unit Amount" },
          "grossAmount": {
            "type": "number",
            "description": "Amount before offsetting debts"
          },
          "netPaid": { "type": "number", "description": "Outgoing payment" },
          "offset": { "type": "number", "description": "Debt settlement" }
        }
      }
    },
    "securitySchemes": {
      "bearer-token": {
        "type": "http",
        "scheme": "bearer",
        "description": "Either island jwt or our own jwt token"
      }
    },
    "responses": {
      "InputError": {
        "description": "Generic input error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Need to authenticate to access resource",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "Access denied",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Requested resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "InternalError": {
        "description": "Unknown internal error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  },
  "security": [{ "bearer-token": [] }]
}
