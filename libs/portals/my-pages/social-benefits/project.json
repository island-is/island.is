{
  "name": "portals-my-pages-social-benefits",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/portals/my-pages/social-benefits/src",
  "projectType": "library",
  "tags": [
    "lib:portals-mypages",
    "scope:portals-mypages"
  ],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/portals/my-pages/social-benefits/jest.config.js"
      },
      "outputs": [
        "{workspaceRoot}/coverage/libs/portals/my-pages/social-benefits"
      ]
    },
    "extract-strings": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yarn ts-node -P libs/localization/tsconfig.lib.json libs/localization/scripts/extract 'libs/portals/my-pages/social-benefits/src/{lib,components,screens}/**/*.{js,ts,tsx}'"
      }
    },
    "codegen/frontend-client": {
      "executor": "nx:run-commands",
      "options": {
        "output": "libs/portals/my-pages/social-benefits/src/**/*.generated.ts",
        "command": "graphql-codegen --config libs/portals/my-pages/social-benefits/codegen.yml"
      }
    }
  }
}