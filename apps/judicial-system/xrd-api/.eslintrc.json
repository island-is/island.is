{
  "extends": "../../../.eslintrc.json",
  "rules": {
    "eqeqeq": ["error", "always"],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "CallExpression[callee.name=/^format(Date)?$/] > Literal[value=/^Pp?$/]",
        "message": "Do not use the date-fns short date token 'P'/'Pp' — the Icelandic locale renders it as 'd.MM.y' (unpadded day, padded month, e.g. \"5.05.2025\"). Use an explicit padded format like 'dd.MM.y' or 'dd.MM.y HH:mm'."
      }
    ],
    "simple-import-sort/imports": [
      "error",
      {
        "groups": [
          // External imports come first.
          ["^\\w", "@(?!nestjs|island\\.is)"],
          // Then nestjs packages.
          ["^@nestjs"],
          // Then island.is packages.
          ["^@island\\.is/(?!judicial-system)"],
          // Then judicial-system packages.
          ["^@island\\.is/judicial-system"],
          // Then all other imports in this order: "../", "./", "./strings", "./css"
          [
            "^\\.\\.(?!/?$)",
            "^\\.\\./?$",
            "^\\./(?=.*/)(?!/?$)",
            "^\\.(?!/?$)",
            "^\\./?$"
          ]
        ]
      }
    ]
  },
  "plugins": ["simple-import-sort"],
  "ignorePatterns": ["!**/*"],
  "overrides": [
    { "files": ["*.ts", "*.tsx", "*.js", "*.jsx"], "rules": {} },
    { "files": ["*.ts", "*.tsx"], "rules": {} },
    { "files": ["*.js", "*.jsx"], "rules": {} }
  ]
}
